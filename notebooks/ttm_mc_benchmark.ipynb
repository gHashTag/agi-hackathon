   "cell_type": "code",
   "execution_count": 1,
   "source": "!pip install -q kaggle-benchmarks kaggle\nimport kaggle.benchmarks as kbench\nimport kaggle\nimport pandas as pd\nimport os, re, glob\nimport matplotlib.pyplot as plt\nimport numpy as np\nos.environ[\"RENDER_SUBRUNS\"] = \"False\"\n\nprint(\"[TTM] Step 9: Create calibration curve\")\n\n# Confidence calibration analysis\ndef plot_calibration(df):\n    if 'confidence' not in df.columns:\n        # Generate synthetic confidence if not present\n        df['confidence'] = df['correct'].apply(lambda x: 1.0 if x else 0.0)  \n    \n    bins = 10\n    df['conf_bin'] = pd.cut(df['confidence'], bins=bins, labels=False)\n    \n    # Calibration curve\n    bin_accuracy = df.groupby('conf_bin').apply(lambda x: (x['correct'] / x.shape[0]).mean())\n    \n    fig, ax = plt.subplots(figsize=(10, 6))\n    ax.plot(bin_accuracy.index, bin_accuracy.values, marker='o-', label='Calibration')\n    ax.plot([0, 1], color='green', linestyle='--', label='Perfectly Calibrated')\n    ax.set_xlabel('Confidence')\n    ax.set_ylabel('Accuracy')\n    ax.set_title('TTM Calibration Curve')\n    ax.legend(['Underconfident', 'Overconfident'])\n    ax.grid(True)\n    plt.tight_layout()\n    plt.savefig('ttm_calibration_curve.png')\n    print('[TTM] Saved: ttm_calibration_curve.png')\n    \n    # Brier score (if confidence available)\n    brier = ((df['confidence'] - df['correct']) ** 2).mean()\n    print(f'[TTM] Brier Score: {brier:.4f}')\n\nplot_calibration(df_combined)"
