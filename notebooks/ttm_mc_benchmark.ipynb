   "source": "!pip install protobuf==5.29.6 --quiet\n!pip install -q kaggle-benchmarks kaggle\nimport kaggle.benchmarks as kbench\nimport kaggle\nimport pandas as pd\nimport os, re, glob\nos.environ[\"RENDER_SUBRUNS\"] = \"False\"\nimport kaggle.benchmarks as kbench\nimport kaggle\nimport pandas as pd\nfrom dataclasses import dataclass\nprint(\"[TTM] Step 0: kbench v{kbench.__version__}\")",
   {
   "cell_type": "markdown",
   "execution_count": null,
   "source": "# Load TTM Dataset\n\n```python\nimport os, re, glob\nos.environ[\"RENDER_SUBRUNS\"] = \"False\"\nimport kaggle.benchmarks as kbench\nimport kaggle\nimport pandas as pd\nprint(\"[TTM] Step 1: Imports OK\")\n\nprint(\"[TTM] Step 2: Downloading kaggle/trinity-cognitive-probes-tmp-mc\")\nos.makedirs('/kaggle/working/data', exist_ok=True)\nkbench.api.dataset_download_files('kaggle/trinity-cognitive-probes-tmp-mc',\n                                path='/kaggle/working/data', unzip=True)\n\ncsv_files = glob.glob('/kaggle/working/data/**/*.csv', recursive=True)\nprint(f\"[TTM] Available CSVs: {csv_files}\")\n\nCSV_PATH = next((f for f in csv_files if 'ttm_mc' in f.lower()), None)\nif CSV_PATH is None:\n    raise FileNotFoundError(f'[TTM] ttm_mc.csv not found in {csv_files}')\nprint(f\"[TTM] Step 3: Using {CSV_PATH}\")\n\n# Load adversarial physics-enhanced dataset\nADV_PATH = 'kaggle/data/extra/ttm_mc_physics_mc.csv'\nif not os.path.exists(ADV_PATH):\n    print(f\"[TTM] Warning: {ADV_PATH} not found, using original\")\n    ADV_PATH = CSV_PATH\n\n\ndf_adv = pd.read_csv(ADV_PATH)\nprint(f\"[TTM] Loaded: {len(df_adv)} rows (Physics Enhanced)\")\n\ndf_orig = pd.read_csv(CSV_PATH)\nprint(f\"[TTM] Original: {len(df_orig)} rows\")\n\n# Combine datasets\nndf_combined = pd.concat([df_orig, df_adv], ignore_index=True)\nprint(f\"[TTM] Combined: {len(df_combined)} rows\")\n\n# Display data\nprint(df_combined.head(10))"
  },
  {
   "cell_type": "markdown",
   "execution_count": null,
   "source": "# Data Preprocessing\n\n```python\n# Convert to MC format\nif 'question_type' not in df_combined.columns:\n    df_combined['question_type'] = 'mc'\n\n# Strip whitespace from answers\ndf_combined['answer'] = df_combined['answer'].astype(str).str.strip().str.upper()\n\n# Validate answer format\ndef validate_answer(ans):\n    if not ans or ans not in ['A', 'B', 'C', 'D']:\n        return False\n    return True\n\nvalid = df_combined['answer'].apply(validate_answer)\nprint(f\"[TTM] Valid answers: {valid.sum()}/{len(valid)} = {valid.sum()/len(valid):.2%}\")\nassert valid.mean() > 0.95, 'Answer validity below 95%'\n\n# Display distribution\nprint(df_combined['answer'].value_counts(normalize=True).sort_index())"
