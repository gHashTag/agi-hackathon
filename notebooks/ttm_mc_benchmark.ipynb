   "source": "!pip install -q kaggle-benchmarks kaggle\nimport kaggle.benchmarks as kbench\nimport kaggle\nimport pandas as pd\nimport os, re, glob\nimport matplotlib.pyplot as plt\nimport numpy as np\nos.environ[\"RENDER_SUBRUNS\"] = \"False\"\n\nprint(\"[TTM] Step 8: Create performance charts\")\n\n# Performance by domain\ndomain_counts = df_combined['answer'].value_counts(normalize=True).sort_index()\nfig, ax = plt.subplots(figsize=(10, 6))\ndomain_counts.plot(kind='bar', ax=ax)\nax.set_xlabel('Cognitive Domain')\nax.set_ylabel('Number of Questions')\nax.set_title('TTM Performance by Cognitive Domain')\nplt.tight_layout()\nplt.savefig('ttm_performance_by_domain.png')\nprint('[TTM] Saved: ttm_performance_by_domain.png')"
