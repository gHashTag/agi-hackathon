  {
   "cell_type": "code",
   "execution_count": 1,
   "source": "!pip install -q kaggle-benchmarks kaggle\nimport kaggle-benchmarks as kbench\nimport kaggle\nimport os, re, glob\nos.environ[\"RENDER_SUBRUNS\"] = \"False\"\nimport kaggle.benchmarks as kbench\nimport kaggle\nfrom dataclasses import dataclass\n\nfrom MCAnswer import MCAnswer\nprint(\"[THLP] Step 5: kbench ready\")",
   {
   "cell_type": "markdown",
   "source": "## THLP MC Evaluation\n\n\n```python\nfrom MCAnswer import MCAnswer\n\nimport kaggle.benchmarks as kbench\n\nimport pandas as pd\n\n@dataclass\nclass THLPEval:\n    llm: str\n    accuracy: float\n    accuracy_per_class: dict\n    calibration_error: float\n    sample_size: int\n\n    total_questions: int\n\ndef evaluate_thlp_mc(df):\n    # Inner task definition\n    @kbench.task(name='thlp_single_mc', store_task=False)\n    def thlp_single_mc(llm, question: str, choices: str,\n                       expected_answer: str) -> bool:\n        prompt = f\"\"{question}\\n\\n\\n{choices}\\n\\nAnswer with ONLY ONE letter (A, B, C, or D). Do not explain.\"\n        try:\n            response = llm.prompt(prompt, schema=MCAnswer)\n            got = response.answer.strip().upper()[:1]\n            is_correct = got == expected_answer\n            # print(f\"{question[:50]}...{got}...{expected_answer}...{is_correct}\")\n        except Exception as e:\n            print(f\"Error: {e}\")\n            is_correct = False\n        \n        llm.logger.info(f\"Evaluation: {question}, {got}, {expected_answer}, {is_correct}\")\n    \n        # Calculate metrics\n    accuracy = sum([is_correct for _, response in llm.stream]) / 100\n    \n    # Per-class accuracy\n    class_counts = pd.Series([is_correct for _, response in llm.stream]).value_counts()\n    \n    # Calibration error (Brier score)\n    confidence = sum([response.confidence for _, response in llm.stream if hasattr(response, 'confidence')]) / (100 if hasattr(response, 'confidence') else 1)\n    \n    calibration_error = ((confidence - is_correct) ** 2).sum() / 100\n    \n    return {\n        \"accuracy\": accuracy,\n        \"class_accuracy\": class_counts.to_dict(),\n        \"calibration_error\": calibration_error,\n        \"confidence\": confidence\n    }\n\n\neval_res = llm.evaluate(llm, evaluation_data=eval_df)\n    \n    # Extract metrics\n    accuracy = neval_res.metrics['accuracy']\n    calibration_error = neval_res.metrics.get('calibration_error', 0)\n    \n    # Create results DataFrame\n    results = pd.DataFrame([{\n        \"question\": [q.question for q in eval_df['evaluation_data']['question'][:5]],\n        \"llm_answer\": [r.llm_answer for r in llm.stream],\n        \"expected_answer\": [r.expected_answer for r in llm.stream],\n        \"is_correct\": [r.is_correct for r in llm.stream],\n        \"question_id\": [q.question_id for q in eval_df['evaluation_data']['question'][:5]]\n    }])\n    \n    # Add metadata\n    metadata = {\n        \"title\": \"THLP MC Results\",\n        \"description\": f\"Model: {llm}, Accuracy: {accuracy:.2%}\",\n        \"tags\": [\"evaluation\", \"kaggle-benchmarks\"],\n        \"dataset_sources\": [\"playra/trinity-cognitive-probes-thlp-mc\"]\n    }\n    \n    kbench.submit(run_name='thlp_mc', results_df=results, meta=metadata)\n    \n    print(f\"[THLP] Step 6: Submitted to kbench\")"
